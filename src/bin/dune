(executable
 (name main)
 (public_name vpnkit)
 (libraries cmdliner ofs logs.fmt hostnet hvsock hvsock.lwt
   fd-send-recv duration mirage-clock-unix mirage-random
   fs9p mirage-random-stdlib dune-build-info)
 (flags
  :standard
  (:include flags.sexp))
 (preprocess no_preprocessing))

(env
  (dynamic
    ;; set DYNAMIC to some value when building in dynamic profile
    (env-vars
      (DYNAMIC 1))))

(rule
 (targets flags.sexp)
 (deps (env_var DYNAMIC))
 (action
  (run config/discover.exe)))
